# Copy this file to .env and fill in what you have.
# The agent works with ZERO keys set (it degrades to a deterministic
# template-based generator), but quality is much higher with a real LLM.

# --- Primary provider: Groq (free tier, very fast Llama 3.1 inference) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Secondary/fallback provider: Ollama (runs 100% locally, no key needed) ---
# Install from https://ollama.com, then: `ollama pull llama3.1`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Output directory for generated Word documents ---
OUTPUT_DIR=generated_docs
